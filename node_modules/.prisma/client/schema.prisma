generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  phone    String?
  role     String // owner / society

  kos      Kos[]     @relation("OwnerKos")
  bookings Booking[]
  comments Comment[]
}

model Kos {
  id      Int    @id @default(autoincrement())
  name    String
  address String
  price   Int
  gender  String // male / female / all

  ownerId Int
  owner   User @relation("OwnerKos", fields: [ownerId], references: [id])

  images    KosImage[]
  fasilitas Fasilitas[]
  bookings  Booking[]
  comments  Comment[]
}

model KosImage {
  id    Int    @id @default(autoincrement())
  image String

  kosId Int
  kos   Kos @relation(fields: [kosId], references: [id])
}

model Fasilitas {
  id   Int    @id @default(autoincrement())
  name String

  kosId Int
  kos   Kos @relation(fields: [kosId], references: [id])
}

model Booking {
  id        Int      @id @default(autoincrement())
  startDate DateTime
  endDate   DateTime
  status    String // pending / accept / reject

  kosId Int
  kos   Kos @relation(fields: [kosId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])
}

model Comment {
  id      Int    @id @default(autoincrement())
  comment String

  kosId Int
  kos   Kos @relation(fields: [kosId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])
}
